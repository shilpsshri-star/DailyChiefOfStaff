ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# From your Supabase project: Settings -> API. NEXT_PUBLIC_SUPABASE_URL and
# NEXT_PUBLIC_SUPABASE_ANON_KEY are safe to expose to the browser, but this
# app only uses the service role key server-side in API routes (see
# lib/supabase.ts) -- the anon key isn't actually used yet, it's here in case
# you want client-side Supabase access later. Run migration.sql in the
# Supabase SQL editor before first use.
#
# IMPORTANT: SUPABASE_SERVICE_ROLE_KEY must be the "service_role" key, not
# the "anon public" key -- using the anon key here will make every insert
# silently fail Row Level Security (see migration.sql).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional but recommended: Clerk Dashboard -> Webhooks -> Add Endpoint
# (URL: https://<your-domain>/api/webhooks/clerk, events: user.created,
# user.updated) -> copy the "Signing Secret" shown after creating it. This
# creates each user's Supabase row immediately at sign-up with their email.
# Without it, the app still works -- every authenticated API route creates
# the row on first use via lib/auth.ts's requireUserId() -- it just won't
# have an email attached until something else sets one.
CLERK_WEBHOOK_SIGNING_SECRET=

# Only needed to run the local MCP server (npm run mcp -- see README's "MCP
# server" section). Set this to your own Clerk user id: open Supabase ->
# Table editor -> users, copy the `id` column for your row. The MCP server
# uses the same Supabase env vars above plus this one to scope every tool
# call to you -- it's a personal tool, not a multi-tenant API.
MCP_USER_ID=

# Optional, only for the MCP server's calendar sync (mcp-server/calendar-client.ts).
# When set, setting a milestone's target date also creates an all-day event
# on your primary Google Calendar via Google's own Calendar MCP server. This
# is a short-lived OAuth access token (~1hr), not a real OAuth app -- see
# calendar-client.ts for how to generate one via the OAuth Playground. Leave
# blank to skip calendar sync entirely; the rest of the MCP server still works.
GOOGLE_CALENDAR_ACCESS_TOKEN=
